# 博客后端环境配置
# 复制此文件为 .env 并修改以下配置

# 管理员账号（请务必修改！）
ADMIN_USERNAME=admin

# 管理员密码哈希（使用 bcryptjs 生成，命令: node -e "const bcrypt = require('bcryptjs'); bcrypt.hash('your_password', 10).then(h => console.log(h))"）
ADMIN_PASSWORD_HASH=

# JWT 密钥（请替换为一个随机长字符串）
JWT_SECRET=your-random-secret-key-here

# 服务端口
PORT=3000

# 上传文件大小限制（MB）
MAX_FILE_SIZE=10

# 允许的跨域来源（生产环境请设置为具体域名，如: https://your-domain.com）
# ALLOWED_ORIGINS=https://your-domain.com
