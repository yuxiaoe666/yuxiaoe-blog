# 博客后端环境配置
# 复制此文件为 .env 并修改以下配置

# 管理员账号密码（请务必修改！）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-password-here

# JWT 密钥（请替换为一个随机长字符串）
JWT_SECRET=your-random-secret-key-here

# 服务端口
PORT=3000

# 上传文件大小限制（MB）
MAX_FILE_SIZE=10

# 允许的跨域来源（生产环境请设置为具体域名，如: https://your-domain.com）
# ALLOWED_ORIGINS=https://your-domain.com
